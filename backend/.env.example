PORT=3101
HOST=0.0.0.0
CORS_ORIGIN=https://your-frontend-domain.com
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_before_live
ASSESSMENT_URL=https://docs.google.com/forms/d/e/your-form-id/viewform
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_WHATSAPP_NUMBER=919999999999
MSG91_TEMPLATE_NAME=your_approved_template_name
MSG91_TEMPLATE_NAMESPACE=
MSG91_TEMPLATE_LANGUAGE=en

# Comma-separated parameter names from your approved MSG91 template.
# Supported values: assessmentUrl, message, name, patientName, customer_name, uhid.
MSG91_TEMPLATE_HEADER_VARIABLES=
MSG91_TEMPLATE_VARIABLES=customer_name

# Report WhatsApp template. Create an approved template with variables such as
# customer_name and report_url, then set these values.
MSG91_REPORT_TEMPLATE_NAME=
MSG91_REPORT_TEMPLATE_VARIABLES=customer_name,report_url

# Public URL for this backend, required for WhatsApp report links.
# Example: https://your-domain.com or an ngrok HTTPS URL during local testing.
PUBLIC_REPORT_BASE_URL=
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_GID=your_response_sheet_gid
GOOGLE_SHEET_RANGE=A:ZZ
# Optional: use this instead if your published/export URL is different.
GOOGLE_SHEET_CSV_URL=
# Optional private-sheet access. Share the Sheet with the service account client_email.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=
